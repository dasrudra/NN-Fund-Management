<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="view_nn_incoming_fund_list" model="ir.ui.view">
        <field name="name">nn.incoming.fund.list</field>
        <field name="model">nn.incoming.fund</field>
        <field name="arch" type="xml">
            <list string="Incoming Funds"
                  default_order="transaction_date desc, id desc"
                  decoration-success="state == 'confirmed'"
                  decoration-warning="state == 'submitted'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="transaction_date"/>
                <field name="transaction_reference"/>
                <field name="source_name"/>
                <field name="fund_account_id"/>
                <field name="payment_method" optional="show"/>
                <field name="amount" sum="Total Incoming"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="company_id"
                       groups="base.group_multi_company"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

```
<record id="view_nn_incoming_fund_form" model="ir.ui.view">
    <field name="name">nn.incoming.fund.form</field>
    <field name="model">nn.incoming.fund</field>
    <field name="arch" type="xml">
        <form string="Incoming Fund">
            <header>
                <button name="action_submit"
                        type="object"
                        string="Submit"
                        class="btn-primary"
                        invisible="state != 'draft'"
                        groups="nn_fund_management.group_fund_finance"/>

                <button name="action_confirm"
                        type="object"
                        string="Confirm"
                        class="btn-primary"
                        invisible="state != 'submitted'"
                        groups="nn_fund_management.group_fund_finance"/>

                <button name="action_cancel"
                        type="object"
                        string="Cancel"
                        invisible="state != 'draft' and state != 'submitted'"
                        groups="nn_fund_management.group_fund_finance"/>

                <button name="action_reset_to_draft"
                        type="object"
                        string="Reset to Draft"
                        invisible="state != 'cancelled'"
                        groups="nn_fund_management.group_fund_finance"/>

                <field name="state"
                       widget="statusbar"
                       statusbar_visible="draft,submitted,confirmed,cancelled"/>
            </header>

            <sheet>
                <div class="oe_title">
                    <label for="name"/>
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                </div>

                <group>
                    <group string="Transaction Information">
                        <field name="fund_account_id"
                               readonly="state != 'draft'"/>

                        <field name="transaction_reference"
                               readonly="state != 'draft'"
                               placeholder="e.g. BANK-TXN-2026-0001"/>

                        <field name="transaction_date"
                               readonly="state != 'draft'"/>

                        <field name="source_name"
                               readonly="state != 'draft'"
                               placeholder="e.g. Client, donor, or funding source"/>

                        <field name="payment_method"
                               readonly="state != 'draft'"/>
                    </group>

                    <group string="Financial Information">
                        <field name="amount"
                               readonly="state != 'draft'"/>

                        <field name="currency_id"
                               readonly="1"/>

                        <field name="company_id"
                               readonly="1"
                               groups="base.group_multi_company"/>

                        <field name="proof_filename"
                               invisible="1"/>

                        <field name="proof_file"
                               filename="proof_filename"
                               readonly="state != 'draft'"/>
                    </group>
                </group>

                <group string="Notes">
                    <field name="note"
                           nolabel="1"
                           readonly="state != 'draft'"
                           placeholder="Optional transaction details..."/>
                </group>

                <group string="Workflow Audit">
                    <group>
                        <field name="submitted_by_id"
                               readonly="1"
                               invisible="not submitted_by_id"/>

                        <field name="submitted_date"
                               readonly="1"
                               invisible="not submitted_date"/>

                        <field name="confirmed_by_id"
                               readonly="1"
                               invisible="not confirmed_by_id"/>

                        <field name="confirmed_date"
                               readonly="1"
                               invisible="not confirmed_date"/>
                    </group>

                    <group>
                        <field name="cancelled_by_id"
                               readonly="1"
                               invisible="not cancelled_by_id"/>

                        <field name="cancelled_date"
                               readonly="1"
                               invisible="not cancelled_date"/>
                    </group>
                </group>
            </sheet>

            <chatter/>
        </form>
    </field>
</record>

<record id="view_nn_incoming_fund_search" model="ir.ui.view">
    <field name="name">nn.incoming.fund.search</field>
    <field name="model">nn.incoming.fund</field>
    <field name="arch" type="xml">
        <search string="Search Incoming Funds">
            <field name="name"/>
            <field name="transaction_reference"/>
            <field name="source_name"/>
            <field name="fund_account_id"/>
            <field name="company_id"/>

            <separator/>

            <filter name="filter_draft"
                    string="Draft"
                    domain="[('state', '=', 'draft')]"/>

            <filter name="filter_submitted"
                    string="Submitted"
                    domain="[('state', '=', 'submitted')]"/>

            <filter name="filter_confirmed"
                    string="Confirmed"
                    domain="[('state', '=', 'confirmed')]"/>

            <filter name="filter_cancelled"
                    string="Cancelled"
                    domain="[('state', '=', 'cancelled')]"/>

            <separator/>

            <filter name="filter_transaction_date"
                    string="Transaction Date"
                    date="transaction_date"/>

            <group>
                <filter name="group_by_account"
                        string="Fund Account"
                        context="{'group_by': 'fund_account_id'}"/>

                <filter name="group_by_state"
                        string="Status"
                        context="{'group_by': 'state'}"/>

                <filter name="group_by_payment_method"
                        string="Payment Method"
                        context="{'group_by': 'payment_method'}"/>

                <filter name="group_by_company"
                        string="Company"
                        context="{'group_by': 'company_id'}"
                        groups="base.group_multi_company"/>
            </group>
        </search>
    </field>
</record>

<record id="action_nn_incoming_fund" model="ir.actions.act_window">
    <field name="name">Incoming Funds</field>
    <field name="res_model">nn.incoming.fund</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id"
           ref="view_nn_incoming_fund_search"/>

    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Record your first incoming fund
        </p>

        <p>
            Confirmed incoming funds increase the unassigned
            balance of the selected Fund Account.
        </p>
    </field>
</record>
