<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Odoo 19 access-right privilege sections -->

    <record id="privilege_fund_operations" model="res.groups.privilege">
        <field name="name">Fund Operations</field>
        <field name="sequence">30</field>
        <field name="category_id" ref="base.module_category_accounting"/>
    </record>

    <record id="privilege_fund_finance" model="res.groups.privilege">
        <field name="name">Fund Finance</field>
        <field name="sequence">31</field>
        <field name="category_id" ref="base.module_category_accounting"/>
    </record>

    <record id="privilege_fund_gm_approval" model="res.groups.privilege">
        <field name="name">Fund GM Approval</field>
        <field name="sequence">32</field>
        <field name="category_id" ref="base.module_category_accounting"/>
    </record>

    <record id="privilege_fund_md_approval" model="res.groups.privilege">
        <field name="name">Fund MD Approval</field>
        <field name="sequence">33</field>
        <field name="category_id" ref="base.module_category_accounting"/>
    </record>

    <record id="privilege_fund_administration" model="res.groups.privilege">
        <field name="name">Fund Administration</field>
        <field name="sequence">34</field>
        <field name="category_id" ref="base.module_category_accounting"/>
    </record>

    <!-- Required roles -->

    <record id="group_fund_user" model="res.groups">
        <field name="name">Fund User</field>
        <field name="comment">
            Can access fund-management records and create operational requests
            according to the relevant workflow permissions.
        </field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="privilege_fund_operations"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_fund_finance" model="res.groups">
        <field name="name">Finance User</field>
        <field name="comment">
            Can manage fund accounts, expense heads, incoming funds,
            and finance-controlled transactions.
        </field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="privilege_fund_finance"/>
        <field name="implied_ids"
               eval="[(4, ref('nn_fund_management.group_fund_user'))]"/>
    </record>

    <record id="group_fund_gm_approver" model="res.groups">
        <field name="name">GM Approver</field>
        <field name="comment">
            Can review and process the General Manager approval stage.
        </field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="privilege_fund_gm_approval"/>
        <field name="implied_ids"
               eval="[(4, ref('nn_fund_management.group_fund_user'))]"/>
    </record>

    <record id="group_fund_md_approver" model="res.groups">
        <field name="name">MD Approver</field>
        <field name="comment">
            Can review and process the Managing Director approval stage.
        </field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="privilege_fund_md_approval"/>
        <field name="implied_ids"
               eval="[(4, ref('nn_fund_management.group_fund_user'))]"/>
    </record>

    <record id="group_fund_admin" model="res.groups">
        <field name="name">Fund Administrator</field>
        <field name="comment">
            Has full configuration, operational, approval,
            security, and audit access within Fund Management.
        </field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="privilege_fund_administration"/>
        <field name="implied_ids"
               eval="[
                   (4, ref('nn_fund_management.group_fund_finance')),
                   (4, ref('nn_fund_management.group_fund_gm_approver')),
                   (4, ref('nn_fund_management.group_fund_md_approver'))
               ]"/>
        <field name="user_ids"
               eval="[
                   (4, ref('base.user_root')),
                   (4, ref('base.user_admin'))
               ]"/>
    </record>

    <!-- Global multi-company record rules -->

    <record id="rule_fund_account_multi_company" model="ir.rule">
        <field name="name">Fund Account: multi-company isolation</field>
        <field name="model_id" ref="model_nn_fund_account"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids)]
        </field>
    </record>

    <record id="rule_expense_head_multi_company" model="ir.rule">
        <field name="name">Expense Head: multi-company isolation</field>
        <field name="model_id" ref="model_nn_expense_head"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids)]
        </field>
    </record>
        <record id="rule_incoming_fund_multi_company" model="ir.rule">
        <field name="name">
            Incoming Fund: multi-company isolation
        </field>
        <field name="model_id" ref="model_nn_incoming_fund"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids)]
        </field>
    </record>
        <record id="rule_fund_allocation_multi_company" model="ir.rule">
        <field name="name">
            Fund Allocation: multi-company isolation
        </field>
        <field name="model_id" ref="model_nn_fund_allocation"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids)]
        </field>
    </record>
</odoo>
